#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

./scripts/check-agent-team

echo "Starting coder and reviewer through HCOM..."
hcom codex --tag algorithm-coder --dir "$(pwd)" --hcom-system-prompt "$(cat 'development approach/prompts/algorithm_coder_prompt.md')"
hcom claude --tag algorithm-reviewer --dir "$(pwd)" --hcom-system-prompt "$(cat 'development approach/prompts/algorithm_reviewer_prompt.md')"
hcom codex --tag ux-coder --dir "$(pwd)" --hcom-system-prompt "$(cat 'development approach/prompts/ux_coder_prompt.md')"
hcom claude --tag ux-reviewer --dir "$(pwd)" --hcom-system-prompt "$(cat 'development approach/prompts/ux_reviewer_prompt.md')"

echo
echo "Optional orchestrator:"
echo "  ./scripts/start-orchestrator"
