#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import random
import resource
import time
from collections import Counter
from dataclasses import dataclass
from pathlib import Path
from typing import Callable

import numpy as np

from bot_hunter.data import ClickEvent, build_features, parse_clicks
from bot_hunter.heuristics import apply_heuristics
from bot_hunter.ml import _standardize


SEED = 7
EPOCHS = 8
BATCH_SIZE = 2048
HIDDEN_DIM = 32
LATENT_DIM = 8
VAE_KL_WEIGHT = 0.001


@dataclass(frozen=True)
class ModelResult:
    name: str
    runtime_seconds: float
    approximate_peak_memory_mb: float
    flagged_event_ids: set[str]
    ml_scores: list[float]
    combined_scores: list[float]
    threshold: float
    summary: dict[str, object]


def main() -> None:
    parser = argparse.ArgumentParser(description="Benchmark neural anomaly scorers against Isolation Forest.")
    parser.add_argument("--input", default="data/bot-hunter-dataset.tsv", help="Raw click TSV path")
    parser.add_argument("--output", help="Optional JSON output path")
    parser.add_argument("--epochs", default=EPOCHS, type=int, help="Training epochs for neural models")
    parser.add_argument("--batch-size", default=BATCH_SIZE, type=int, help="Training batch size")
    args = parser.parse_args()

    _set_seed(SEED)
    events = parse_clicks(args.input)
    feature_names, counters = build_features(events)
    apply_heuristics(events, counters)
    matrix = np.asarray([event.features for event in events], dtype=np.float32)
    scaled = np.asarray(_standardize(matrix.tolist())[0], dtype=np.float32)

    scorers: list[tuple[str, Callable[[np.ndarray], list[float]]]] = [
        ("isolation_forest", _score_isolation_forest),
        (
            "autoencoder",
            lambda rows: _score_autoencoder(rows, epochs=args.epochs, batch_size=args.batch_size),
        ),
        ("vae", lambda rows: _score_vae(rows, epochs=args.epochs, batch_size=args.batch_size)),
    ]
    results = [run_model(name, scorer, scaled, events, counters) for name, scorer in scorers]
    baseline = results[0]
    payload = {
        "input_path": str(Path(args.input)),
        "total_events": len(events),
        "feature_count": len(feature_names),
        "feature_names": feature_names,
        "methodology": (
            "Existing 15-feature matrix standardized once; existing heuristic scores; "
            "ml_score from rank-normalized anomaly values; existing combined rule "
            "combined_score=(0.58*heuristic_score)+(0.42*ml_score); flag when combined "
            "score is above the 97.5th percentile cutoff or heuristic_score >= 0.62."
        ),
        "settings": {
            "seed": SEED,
            "device": "cpu",
            "epochs": args.epochs,
            "batch_size": args.batch_size,
            "autoencoder": {
                "architecture": f"{len(feature_names)}->{HIDDEN_DIM}->{LATENT_DIM}->{HIDDEN_DIM}->{len(feature_names)}",
                "loss": "mean squared reconstruction error",
                "optimizer": "Adam(lr=0.001)",
            },
            "vae": {
                "architecture": f"encoder {len(feature_names)}->{HIDDEN_DIM}->mu/logvar({LATENT_DIM}); decoder {LATENT_DIM}->{HIDDEN_DIM}->{len(feature_names)}",
                "loss": f"mean squared reconstruction error + {VAE_KL_WEIGHT}*KL divergence",
                "optimizer": "Adam(lr=0.001)",
            },
        },
        "models": [_with_baseline_metrics(result, baseline) for result in results],
    }
    text = json.dumps(payload, indent=2)
    if args.output:
        Path(args.output).write_text(text + "\n", encoding="utf-8")
    print(text)


def run_model(
    name: str,
    scorer: Callable[[np.ndarray], list[float]],
    scaled: np.ndarray,
    events: list[ClickEvent],
    counters: dict[str, Counter],
) -> ModelResult:
    start = time.perf_counter()
    anomaly_values = scorer(scaled)
    ml_scores = _rank_scores(anomaly_values)
    combined_scores = [(0.58 * event.heuristic_score) + (0.42 * ml_score) for event, ml_score in zip(events, ml_scores)]
    threshold = _quantile(combined_scores, 0.975)
    flagged = {
        event.event_id
        for event, combined_score in zip(events, combined_scores)
        if combined_score >= threshold or event.heuristic_score >= 0.62
    }
    runtime = time.perf_counter() - start
    return ModelResult(
        name=name,
        runtime_seconds=runtime,
        approximate_peak_memory_mb=_peak_memory_mb(),
        flagged_event_ids=flagged,
        ml_scores=ml_scores,
        combined_scores=combined_scores,
        threshold=threshold,
        summary=_summarize_model(name, events, counters, flagged, ml_scores, combined_scores, threshold, runtime),
    )


def _score_isolation_forest(rows: np.ndarray) -> list[float]:
    from sklearn.ensemble import IsolationForest

    model = IsolationForest(random_state=SEED, contamination="auto")
    model.fit(rows)
    return [-float(score) for score in model.decision_function(rows)]


def _score_autoencoder(rows: np.ndarray, epochs: int, batch_size: int) -> list[float]:
    import torch
    from torch import nn
    from torch.utils.data import DataLoader, TensorDataset

    torch.manual_seed(SEED)
    torch.set_num_threads(1)
    data = torch.tensor(rows, dtype=torch.float32)
    loader = DataLoader(TensorDataset(data), batch_size=batch_size, shuffle=True)
    model = nn.Sequential(
        nn.Linear(rows.shape[1], HIDDEN_DIM),
        nn.ReLU(),
        nn.Linear(HIDDEN_DIM, LATENT_DIM),
        nn.ReLU(),
        nn.Linear(LATENT_DIM, HIDDEN_DIM),
        nn.ReLU(),
        nn.Linear(HIDDEN_DIM, rows.shape[1]),
    )
    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
    loss_fn = nn.MSELoss()
    model.train()
    for _ in range(epochs):
        for (batch,) in loader:
            optimizer.zero_grad()
            loss = loss_fn(model(batch), batch)
            loss.backward()
            optimizer.step()
    model.eval()
    with torch.no_grad():
        recon = model(data)
        return torch.mean((recon - data) ** 2, dim=1).tolist()


class _VAE:
    def __init__(self, input_dim: int):
        import torch
        from torch import nn

        self.torch = torch
        self.encoder = nn.Sequential(nn.Linear(input_dim, HIDDEN_DIM), nn.ReLU())
        self.mu = nn.Linear(HIDDEN_DIM, LATENT_DIM)
        self.logvar = nn.Linear(HIDDEN_DIM, LATENT_DIM)
        self.decoder = nn.Sequential(nn.Linear(LATENT_DIM, HIDDEN_DIM), nn.ReLU(), nn.Linear(HIDDEN_DIM, input_dim))

    def parameters(self):
        return list(self.encoder.parameters()) + list(self.mu.parameters()) + list(self.logvar.parameters()) + list(
            self.decoder.parameters()
        )

    def train(self) -> None:
        self.encoder.train()
        self.mu.train()
        self.logvar.train()
        self.decoder.train()

    def eval(self) -> None:
        self.encoder.eval()
        self.mu.eval()
        self.logvar.eval()
        self.decoder.eval()

    def __call__(self, rows):
        hidden = self.encoder(rows)
        mu = self.mu(hidden)
        logvar = self.logvar(hidden)
        std = self.torch.exp(0.5 * logvar)
        eps = self.torch.randn_like(std)
        z = mu + eps * std
        return self.decoder(z), mu, logvar

    def reconstruct_from_mean(self, rows):
        hidden = self.encoder(rows)
        return self.decoder(self.mu(hidden)), self.mu(hidden), self.logvar(hidden)


def _score_vae(rows: np.ndarray, epochs: int, batch_size: int) -> list[float]:
    import torch
    from torch.utils.data import DataLoader, TensorDataset

    torch.manual_seed(SEED)
    torch.set_num_threads(1)
    data = torch.tensor(rows, dtype=torch.float32)
    loader = DataLoader(TensorDataset(data), batch_size=batch_size, shuffle=True)
    model = _VAE(rows.shape[1])
    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
    model.train()
    for _ in range(epochs):
        for (batch,) in loader:
            optimizer.zero_grad()
            recon, mu, logvar = model(batch)
            recon_loss = torch.mean((recon - batch) ** 2)
            kl_loss = -0.5 * torch.mean(1 + logvar - mu.pow(2) - logvar.exp())
            loss = recon_loss + (VAE_KL_WEIGHT * kl_loss)
            loss.backward()
            optimizer.step()
    model.eval()
    with torch.no_grad():
        recon, mu, logvar = model.reconstruct_from_mean(data)
        recon_error = torch.mean((recon - data) ** 2, dim=1)
        kl = -0.5 * torch.mean(1 + logvar - mu.pow(2) - logvar.exp(), dim=1)
        return (recon_error + (VAE_KL_WEIGHT * kl)).tolist()


def _summarize_model(
    name: str,
    events: list[ClickEvent],
    counters: dict[str, Counter],
    flagged: set[str],
    ml_scores: list[float],
    combined_scores: list[float],
    threshold: float,
    runtime: float,
) -> dict[str, object]:
    flagged_events = [event for event in events if event.event_id in flagged]
    reason_counter: Counter[str] = Counter()
    for event in flagged_events:
        for reason in event.reasons:
            reason_counter[_normalize_reason(reason)] += 1
    combined_by_event = dict(zip((event.event_id for event in events), combined_scores))
    top_event_ids = [
        event.event_id
        for event in sorted(flagged_events, key=lambda event: combined_by_event[event.event_id], reverse=True)[:10]
    ]
    return {
        "name": name,
        "runtime_seconds": round(runtime, 3),
        "approximate_peak_memory_mb": round(_peak_memory_mb(), 1),
        "flagged_count": len(flagged),
        "ml_tail_rate": sum(1 for score in ml_scores if score >= 0.985) / max(len(ml_scores), 1),
        "threshold": threshold,
        "top_reasons": reason_counter.most_common(8),
        "top_domains": Counter(event.domain for event in flagged_events).most_common(8),
        "top_queries": Counter(event.query for event in flagged_events).most_common(8),
        "top_regions": Counter(event.region for event in flagged_events).most_common(8),
        "top_event_ids": top_event_ids,
        "qualitative_reviewability": _qualitative_reviewability(name),
    }


def _with_baseline_metrics(result: ModelResult, baseline: ModelResult) -> dict[str, object]:
    intersection = result.flagged_event_ids & baseline.flagged_event_ids
    union = result.flagged_event_ids | baseline.flagged_event_ids
    payload = dict(result.summary)
    payload.update(
        {
            "overlap_with_isolation_forest": len(intersection),
            "jaccard_with_isolation_forest": round(len(intersection) / max(len(union), 1), 4),
            "unique_vs_isolation_forest": len(result.flagged_event_ids - baseline.flagged_event_ids),
            "isolation_forest_unique_vs_model": len(baseline.flagged_event_ids - result.flagged_event_ids),
        }
    )
    return payload


def _rank_scores(values: list[float]) -> list[float]:
    ordered = sorted(float(value) for value in values)
    max_rank = max(len(ordered) - 1, 1)
    return [_upper_bound(ordered, float(value)) / max_rank for value in values]


def _upper_bound(values: list[float], needle: float) -> int:
    low = 0
    high = len(values)
    while low < high:
        mid = (low + high) // 2
        if values[mid] <= needle:
            low = mid + 1
        else:
            high = mid
    return low - 1


def _quantile(values: list[float], q: float) -> float:
    ordered = sorted(values)
    idx = min(len(ordered) - 1, max(0, int(round((len(ordered) - 1) * q))))
    return ordered[idx]


def _peak_memory_mb() -> float:
    usage = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss
    if usage > 10_000_000:
        return usage / (1024 * 1024)
    return usage / 1024


def _set_seed(seed: int) -> None:
    random.seed(seed)
    np.random.seed(seed)


def _normalize_reason(reason: str) -> str:
    import re

    reason = re.sub(r"\d+ clicks in the same second", "same-second click burst", reason)
    reason = re.sub(r"query/domain repeated \d+ times", "repeated query/domain pair", reason)
    reason = re.sub(r"query repeated \d+ times", "repeated query", reason)
    reason = re.sub(r"exact time-to-click reused \d+ times", "reused exact time-to-click", reason)
    reason = re.sub(r"high-volume clicked domain \(\d+\)", "high-volume clicked domain", reason)
    reason = re.sub(r"heavy region/browser/os cluster \(\d+\)", "heavy region/browser/os cluster", reason)
    return reason


def _qualitative_reviewability(name: str) -> str:
    if name == "isolation_forest":
        return "Best production fit: fast, stable, already integrated, and its flags align with existing heuristic explanations."
    if name == "autoencoder":
        return "Reviewable only through the same heuristic overlays; reconstruction error adds little direct explanation."
    return "Least reviewable of the benchmarked options because VAE stochastic training adds complexity without clearer event explanations."


if __name__ == "__main__":
    main()
